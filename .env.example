# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE_URL: Required for Supabase integration.
VITE_SUPABASE_URL="https://achubwkoknsjkwhykxow.supabase.co"

# SUPABASE_PUBLISHABLE_KEY: Required for Supabase integration.
# Replaced with your new project's publishable key in the Secrets panel.
VITE_SUPABASE_PUBLISHABLE_KEY="MY_SUPABASE_PUBLISHABLE_KEY"

# GOOGLE_CLIENT_ID: Used for Google OAuth via Supabase
# Value: 690873912766-otrpkgjojfearsa2smfj3hdjb7f8oe0k.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID="690873912766-otrpkgjojfearsa2smfj3hdjb7f8oe0k.apps.googleusercontent.com"

# STRIPE_WEBHOOK_ID: we_1TOPL6RsLFesxj6X1V32obXr
# Ensure you set STRIPE_WEBHOOK_SECRET and STRIPE_SECRET_KEY in the Secrets panel.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

